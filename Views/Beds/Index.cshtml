@model IEnumerable<HospitalManagementSystem.Models.Bed>

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.Ward.WardName)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.BedNumber)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.IsOccupied)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.Ward.WardName)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.BedNumber)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.IsOccupied)
        </td>
        <td>
            @Html.ActionLink("Edit", "Edit", new { id=item.BedId }) |
            @Html.ActionLink("Details", "Details", new { id=item.BedId }) |
            @Html.ActionLink("Delete", "Delete", new { id=item.BedId })
        </td>
    </tr>
}

</table>
