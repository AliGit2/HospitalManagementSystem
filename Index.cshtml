@{
    ViewBag.Title = "Hospital Dashboard";
}

<div class="jumbotron" style="background-color: #2c3e50; color: white; padding: 30px; margin-top: 20px; border-radius: 8px;">
    <h2>Hospital Management Dashboard</h2>
    <p class="lead">System Configuration Tracker — Group Configuration Number (GCN): 2</p>
</div>

<div class="row text-center">
    <div class="col-md-6">
        <div class="panel panel-info" style="border: 2px solid #31708f; border-radius: 6px; padding: 20px; background-color: #f4f9fc; margin-bottom: 20px;">
            <h3 style="color: #31708f; margin-top: 0;">⏱️ Avg Stay Duration</h3>
            <h1 style="font-size: 3.5em; font-weight: bold; margin: 10px 0;">@ViewBag.AvgStayDays <small style="font-size: 0.4em;">Days</small></h1>
            <p class="text-muted" style="margin-bottom: 0;">Dynamically processed from active historical discharge data.</p>
        </div>
    </div>

    <div class="col-md-6">
        <div class="panel panel-success" style="border: 2px solid #3c763d; border-radius: 6px; padding: 20px; background-color: #f5f9f5; margin-bottom: 20px;">
            <h3 style="color: #3c763d; margin-top: 0;">📊 Bed Utilization</h3>
            <h1 style="font-size: 3.5em; font-weight: bold; margin: 10px 0;">@ViewBag.BedUtilization%</h1>
            <p class="text-muted" style="margin-bottom: 0;">Real-time ratio of clinical bed resource availability.</p>
        </div>
    </div>
</div>

<div class="row text-center" style="margin-top: 10px;">
    <div class="col-md-6">
        <div class="well" style="padding: 15px; border-radius: 6px; background-color: #f5f5f5; border: 1px solid #e3e3e3;">
            <h4>Total Registered Patients: <strong>@ViewBag.TotalPatients</strong></h4>
        </div>
    </div>
    <div class="col-md-6">
        <div class="well" style="padding: 15px; border-radius: 6px; background-color: #f5f5f5; border: 1px solid #e3e3e3;">
            <h4>Active Medical Staff: <strong>@ViewBag.TotalDoctors</strong></h4>
        </div>
    </div>
</div>